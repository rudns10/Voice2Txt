<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Voice2Txt.Gui.Views.SaveRecordingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="녹음 저장"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryClick">

    <StackPanel Spacing="12" Width="380">
        <StackPanel Spacing="4">
            <TextBlock Text="파일명" />
            <TextBox x:Name="NameBox" PlaceholderText="녹음 이름" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="저장 위치" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox" Grid.Column="0" IsReadOnly="True" />
                <Button x:Name="BrowseButton" Grid.Column="1" Content="찾아보기" Click="OnBrowse" />
            </Grid>
        </StackPanel>

        <Border CornerRadius="5" Padding="12" Margin="0,4,0,0"
                Background="{ThemeResource AccentSoftBrush}"
                BorderBrush="{ThemeResource AccentSoftBorderBrush}" BorderThickness="1">
            <CheckBox x:Name="TranscribeCheck" MinWidth="0">
                <StackPanel Spacing="2">
                    <TextBlock Text="지금 텍스트로 변환" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}" />
                    <TextBlock Text="인터넷 없이 로컬에서 처리됩니다 (첫 변환 시 모델 약 190MB 1회 다운로드)"
                               FontSize="12" TextWrapping="Wrap" Foreground="{ThemeResource AccentBrush}" Opacity="0.85" />
                </StackPanel>
            </CheckBox>
        </Border>

        <TextBlock x:Name="ErrorText"
                   Visibility="Collapsed"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
