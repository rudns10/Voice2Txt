<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Voice2Txt.Gui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 목업 팔레트(라이트/다크) -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AppBgColor">#E9EDF2</Color>
                    <SolidColorBrush x:Key="AppBgBrush" Color="#E9EDF2" />
                    <SolidColorBrush x:Key="WinBrush" Color="#FBFBFB" />
                    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="Surface2Brush" Color="#F1F3F6" />
                    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#F5F6F8" />
                    <SolidColorBrush x:Key="HairlineBrush" Color="#14000000" />
                    <SolidColorBrush x:Key="Hairline2Brush" Color="#0F000000" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1B1B" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C5C5C" />
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8C8C8C" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#005FB8" />
                    <SolidColorBrush x:Key="Accent2Brush" Color="#0067C0" />
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF5FC" />
                    <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#CFE4F7" />
                    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="DangerBrush" Color="#C42B1C" />
                    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FDF1F0" />
                    <SolidColorBrush x:Key="DangerSoftBorderBrush" Color="#F3D2CF" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="AppBgColor">#161616</Color>
                    <SolidColorBrush x:Key="AppBgBrush" Color="#161616" />
                    <SolidColorBrush x:Key="WinBrush" Color="#2B2B2B" />
                    <SolidColorBrush x:Key="CardBrush" Color="#2C2C2C" />
                    <SolidColorBrush x:Key="Surface2Brush" Color="#383838" />
                    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#333333" />
                    <SolidColorBrush x:Key="HairlineBrush" Color="#17FFFFFF" />
                    <SolidColorBrush x:Key="Hairline2Brush" Color="#0FFFFFFF" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CCCCCC" />
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#959595" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF" />
                    <SolidColorBrush x:Key="Accent2Brush" Color="#4CC2FF" />
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#102433" />
                    <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#21455E" />
                    <SolidColorBrush x:Key="OnAccentBrush" Color="#06283A" />
                    <SolidColorBrush x:Key="DangerBrush" Color="#FF99A4" />
                    <SolidColorBrush x:Key="DangerSoftBrush" Color="#33201F" />
                    <SolidColorBrush x:Key="DangerSoftBorderBrush" Color="#5A3331" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- 모노 폰트(타임코드/타임스탬프) -->
            <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
